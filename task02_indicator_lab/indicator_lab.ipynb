   "source": [
    "### 3.6 MACD金叉死叉标注\n",
    "\n",
    "**黄金交叉（Golden Cross）**：MACD线上穿信号线，买入信号  \n",
    "**死亡交叉（Death Cross）**：MACD线下穿信号线，卖出信号"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ========== 3.7 检测金叉死叉 ==========\n",
    "# 计算交叉信号\n",
    "df['MACD_cross'] = 0\n",
    "df['MACD_cross'] = np.where(df['MACD'] > df['MACD_signal'], 1, -1)\n",
    "df['MACD_signal_change'] = df['MACD_cross'].diff()\n",
    "\n",
    "# 黄金交叉（从-1变为1）\n",
    "golden_cross = df[df['MACD_signal_change'] == 2]\n",
    "# 死亡交叉（从1变为-1）\n",
    "death_cross = df[df['MACD_signal_change'] == -2]\n",
    "\n",
    "print(f\"📊 黄金交叉数量：{len(golden_cross)}\")\n",
    "print(f\"   死亡交叉数量：{len(death_cross)}\")"
   ]
  },
